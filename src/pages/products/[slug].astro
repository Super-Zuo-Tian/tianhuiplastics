---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import InquiryCTA from "../../components/InquiryCTA.astro";
import { productFamilies } from "../../data/products";
import { images } from "../../data/images";

export async function getStaticPaths() {
  return productFamilies.map((family) => ({
    params: { slug: family.slug },
    props: { family },
  }));
}

const { family } = Astro.props;
---

<BaseLayout
  title={family.name}
  description={family.summary}
>
  <PageHero
    eyebrow={`Resin · ${family.abbreviation}`}
    title={family.name}
    description={family.summary}
    breadcrumb={[
      { label: "Home", href: "/" },
      { label: "Products", href: "/products/" },
      { label: family.abbreviation },
    ]}
    image={images.resinPelletsGrid}
    imagePosition="center"
  >
    <div class="mt-10 flex flex-wrap gap-3">
      {
        family.grades.map((grade) => (
          <a
            href={`#${grade.name.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}
            class="rounded-full border border-white/20 bg-white/5 px-4 py-1.5 text-xs font-semibold text-white transition hover:bg-white/10"
          >
            {grade.name}
          </a>
        ))
      }
    </div>
  </PageHero>

  <!-- SECTION: Overview -->
  <section id="overview" class="bg-white py-24 sm:py-28">
    <Container>
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-8">
          <SectionHeading
            eyebrow="Overview"
            title={`About ${family.name}`}
          />
          <p class="mt-6 text-base leading-7 text-slate-700">
            {family.description}
          </p>
          <p class="mt-4 text-sm text-slate-500">
            Source-material reference: <span class="font-medium text-slate-700">{family.cnName}</span>
          </p>
        </div>
        <aside class="lg:col-span-4">
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8">
            <p class="text-xs font-semibold tracking-wider text-brand-700 uppercase">
              Typical Applications
            </p>
            <ul class="mt-5 space-y-3 text-sm text-slate-700">
              {
                family.applications.map((app) => (
                  <li class="flex gap-3">
                    <span class="mt-2 size-1.5 flex-none rounded-full bg-brand-600" />
                    <span>{app}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- SECTION: Grades / Subcategories -->
  <section id="grades" class="bg-slate-50 py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="Grades & Subcategories"
        title={`${family.abbreviation} grade groups`}
        description={`Each grade group below maps to a subcategory in TIANHUI's ${family.name} portfolio. Replace placeholder copy with brand-specific data sheets and parameters as needed.`}
      />
      <div class="mt-14 grid gap-6 md:grid-cols-2">
        {
          family.grades.map((grade) => {
            const anchor = grade.name.toLowerCase().replace(/[^a-z0-9]+/g, "-");
            return (
              <article id={anchor} class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
                <div class="flex items-center gap-3">
                  <span class="inline-flex size-10 items-center justify-center rounded-xl bg-brand-600/10 text-sm font-semibold text-brand-700">
                    {family.abbreviation}
                  </span>
                  <h3 class="text-lg font-semibold text-slate-900">{grade.name}</h3>
                </div>
                {grade.description && (
                  <p class="mt-4 text-sm leading-7 text-slate-600">{grade.description}</p>
                )}
                {grade.applications && grade.applications.length > 0 && (
                  <div class="mt-6">
                    <p class="text-xs font-semibold tracking-wider text-slate-500 uppercase">
                      Typical Uses
                    </p>
                    <ul class="mt-3 flex flex-wrap gap-2">
                      {grade.applications.map((app) => (
                        <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                          {app}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                {grade.specs && grade.specs.length > 0 && (
                  <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
                    <table class="w-full text-sm">
                      <thead class="bg-slate-50 text-left text-xs font-semibold tracking-wider text-slate-500 uppercase">
                        <tr>
                          <th class="px-4 py-3">Property</th>
                          <th class="px-4 py-3">Value</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-slate-100">
                        {grade.specs.map((spec) => (
                          <tr>
                            <td class="px-4 py-3 text-slate-600">{spec.property}</td>
                            <td class="px-4 py-3 font-medium text-slate-900">{spec.value}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </article>
            );
          })
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Documentation -->
  <section id="documentation" class="bg-white py-24 sm:py-28">
    <Container>
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <SectionHeading
            eyebrow="Documentation"
            title="Data sheets and certificates on request"
            description="Each shipment is accompanied by a COA, mill test report and MSDS. Third-party inspection (SGS, BV, CCIC) can be arranged on request."
          />
        </div>
        <div class="lg:col-span-5">
          <div class="rounded-3xl bg-slate-900 p-8 text-white">
            <p class="text-sm text-slate-300">Need {family.abbreviation} prices or data sheets?</p>
            <p class="mt-2 text-2xl font-semibold">
              Tell us your grade and destination — we will respond within one
              business day.
            </p>
            <a
              href="/contact/"
              class="mt-6 inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-slate-900 hover:bg-slate-100"
            >
              Send an inquiry
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
