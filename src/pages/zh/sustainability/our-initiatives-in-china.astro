---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import PageHero from "../../../components/PageHero.astro";
import SubNav from "../../../components/SubNav.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import InquiryCTA from "../../../components/InquiryCTA.astro";
import { sustainabilityLinksZh } from "../../../data/navSections";
import { images } from "../../../data/images";

const initiatives = [
  {
    title: "塑料回收意识",
    description:
      "与本地学校和社区合作，提升公众对塑料的合理使用、分类与回收意识。",
  },
  {
    title: "慈善与教育支持",
    description:
      "通过年度捐赠与助学项目，支持家乡秦皇岛的学生与教育工作者。",
  },
  {
    title: "灾害救助捐助",
    description:
      "在区域自然灾害期间，配合地方政府与慈善机构提供物资与捐赠。",
  },
  {
    title: "社区体育与文化",
    description:
      "赞助社区体育赛事与文化活动，增进本地联系与居民福祉。",
  },
];

const focusAreas = [
  "通过网络货运平台减少运输空驶里程",
  "优化包装，减少客户现场的废弃物",
  "在可行情况下鼓励使用可回收树脂牌号",
  "与上游伙伴探索更低碳的生产路线",
];
---

<BaseLayout
  title="公益实践"
  description="天晖在国内的公益项目与可持续实践——融合教育、社区与环保工作。"
>
  <PageHero
    eyebrow="社会责任"
    title="公益实践"
    description="自成立以来，天晖累计向慈善事业捐款超过 300 万元人民币——融合经济援助、物资支持与精神鼓励。"
    breadcrumb={[
      { label: "首页", href: "/zh/" },
      { label: "社会责任" },
      { label: "公益实践" },
    ]}
    image={images.teamBuilding}
    imagePosition="center 35%"
  />

  <SubNav links={sustainabilityLinksZh} currentHref="/zh/sustainability/our-initiatives-in-china/" label="栏目导航" />

  <!-- SECTION: Intro -->
  <section id="intro" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <SectionHeading
            eyebrow="承诺"
            title="在所经营的区域，负责任地开展业务"
          />
          <p class="mt-8 text-base leading-7 text-slate-700">
            天晖集团始终把承担更多社会责任视为重要的企业使命，积极参与公益事业，履行企业社会责任。
            这既包括经济援助与物资支持，也包括精神上的鼓励与帮助。
          </p>
          <p class="mt-4 text-base leading-7 text-slate-700">
            自成立以来，公司累计向慈善事业捐款超过 300 万元人民币。未来，我们将继续支持公益事业，
            尽己所能为社会贡献力量。
          </p>
        </div>
        <div class="lg:col-span-5">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.teamGroupPhoto}
              alt="天晖集团团建活动"
              class="aspect-[4/5] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: Initiative cards -->
  <section id="initiatives" class="bg-slate-50 py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="公益方向"
        title="我们投入精力的方向"
        description="以下为部分公益实践的概览。详细报告与合作机构可应要求提供。"
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2">
        {
          initiatives.map((item) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
              <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Focus areas -->
  <section id="focus" class="bg-white py-24 sm:py-28">
    <Container>
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="运营层面"
            title="务实、可衡量的改进"
            description="我们的可持续工作也延伸到日常经营——从物流效率到包装优化。"
          />
        </div>
        <ul class="space-y-4 text-base leading-7 text-slate-700 lg:col-span-7">
          {
            focusAreas.map((area) => (
              <li class="flex gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <span class="mt-2 size-2 flex-none rounded-full bg-brand-600" />
                <span>{area}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </section>

  <InquiryCTA
    title="想进一步了解我们的可持续工作？"
    description="我们乐于分享详细报告，并与公益组织、供应商和客户探讨合作机会。"
    primaryLabel="联系我们的团队"
  />
</BaseLayout>
