---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import PageHero from "../../../components/PageHero.astro";
import SubNav from "../../../components/SubNav.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import InquiryCTA from "../../../components/InquiryCTA.astro";
import { aboutLinksZh } from "../../../data/navSections";
import { images } from "../../../data/images";

const capabilityStats = [
  { value: "30,000 m²", label: "建筑总面积" },
  { value: "2 亿元", label: "2019 年投资额" },
  { value: "300+", label: "全国仓储网点" },
  { value: "24/7", label: "物流运营" },
];

const facilities = [
  {
    title: "销售运营中心",
    description:
      "按树脂系列划分的国内与外贸销售团队，配备双语客户经理与数字化报价工具。",
    image: images.office1,
  },
  {
    title: "接待大厅",
    description:
      "宽敞的接待大厅与安检通道，迎接来访的客户与合作伙伴。",
    image: images.lobby2,
  },
  {
    title: "物流与货运",
    description:
      "多车位装卸平台，全天候作业，拥有合作车队与直达秦皇岛港的运输通道。",
    image: images.trucks,
  },
  {
    title: "售后服务",
    description:
      "对每一批货物提供现场质量检验、应用支持与结构化的客户反馈闭环。",
    image: images.office2,
  },
  {
    title: "网络货运平台",
    description:
      "连接货主与持牌承运方的数字化货运撮合系统，优化运输成本与时效。",
    image: images.freightPlatform,
  },
  {
    title: "总部园区",
    description:
      "现代化总部园区与宽敞大堂，为员工与来访客户提供完善的配套设施。",
    image: images.lobbyLogoWall,
  },
];

const amenities = [
  { title: "图书与阅览室", image: images.library },
  { title: "员工餐厅", image: images.canteen },
  { title: "篮球场", image: images.basketball },
  { title: "羽毛球场", image: images.badminton },
];
---

<BaseLayout
  title="园区与能力"
  description="天晖物流园区位于秦皇岛，占地约 30,000 平方米，集销售、仓储、物流、研发与售后服务于一体。"
>
  <PageHero
    eyebrow="关于天晖"
    title="园区与能力"
    description="一座占地约 30,000 平方米的一体化物流园区，支撑批量树脂贸易、供应链管理与国际履约——集成于秦皇岛同一园区。"
    breadcrumb={[
      { label: "首页", href: "/zh/" },
      { label: "关于我们", href: "/zh/about/company-profile/" },
      { label: "园区与能力" },
    ]}
    image={images.building2}
    imagePosition="center 55%"
  />

  <SubNav links={aboutLinksZh} currentHref="/zh/about/factory-capability/" label="栏目导航" />

  <!-- SECTION: Capability stats -->
  <section id="capability-overview" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-7">
          <SectionHeading
            eyebrow="天晖电子商务物流园区"
            title="为树脂贸易量身打造的 30,000 平方米园区"
            description="园区于 2019 年投入使用，投资 2 亿元人民币，将销售、物流、研发、售后服务与供应链管理整合到一个运营平台，现为集团总部所在地。"
          />
        </div>
        <dl class="grid grid-cols-2 gap-4 lg:col-span-5">
          {
            capabilityStats.map((stat) => (
              <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
                <dd class="text-3xl font-semibold tracking-tight text-slate-900">
                  {stat.value}
                </dd>
                <dt class="mt-2 text-sm text-slate-500">{stat.label}</dt>
              </div>
            ))
          }
        </dl>
      </div>
    </Container>
  </section>

  <!-- SECTION: Park overview photo -->
  <section id="overview-photo" class="bg-slate-50">
    <Container>
      <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
        <img
          src={images.building1}
          alt="天晖物流园区外景"
          class="aspect-[21/9] w-full object-cover"
          loading="lazy"
        />
      </div>
    </Container>
  </section>

  <!-- SECTION: Facilities -->
  <section id="facilities" class="bg-slate-50 py-24 sm:py-32">
    <Container>
      <SectionHeading
        eyebrow="园区设施"
        title="围绕树脂供应而设计的园区"
        description="园区内每个区域均为安全、清洁、按期处理批量树脂物流而专门设计。"
      />
      <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          facilities.map((item) => (
            <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
              <div class="aspect-[4/3] w-full overflow-hidden bg-slate-100">
                <img
                  src={item.image}
                  alt={item.title}
                  class="size-full object-cover transition duration-500 hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-7">
                <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Lobby showcase -->
  <section id="lobby" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.lobby1}
              alt="天晖集团总部大堂"
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="总部大堂"
            title="迎接全球合作伙伴的开放空间"
            description="从宽敞大堂到洽谈室与展厅，我们的总部以应有的诚意接待国内外合作伙伴，承载长期合作的价值。"
          />
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: Staff amenities -->
  <section id="amenities" class="bg-slate-50 py-24 sm:py-32">
    <Container>
      <SectionHeading
        eyebrow="员工配套"
        title="让员工得以成长的空间"
        description="天晖物流园区配备员工配套设施，支持健康、平衡且充满活力的团队。"
      />
      <ul class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          amenities.map((a) => (
            <li class="overflow-hidden rounded-3xl bg-white shadow-sm ring-1 ring-slate-200">
              <div class="aspect-[4/3] w-full overflow-hidden bg-slate-100">
                <img
                  src={a.image}
                  alt={a.title}
                  class="size-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="p-5 text-sm font-semibold text-slate-800">{a.title}</div>
            </li>
          ))
        }
      </ul>
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
