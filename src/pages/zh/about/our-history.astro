---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import PageHero from "../../../components/PageHero.astro";
import SubNav from "../../../components/SubNav.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import InquiryCTA from "../../../components/InquiryCTA.astro";
import { aboutLinksZh } from "../../../data/navSections";
import { images } from "../../../data/images";

const timeline = [
  {
    year: "2004",
    title: "天晖在秦皇岛成立",
    description:
      "公司以区域塑料树脂经销商起步，聚焦 PE 与 PP 牌号，并与国内石化生产企业建立首批长期合作关系。",
  },
  {
    year: "2010",
    title: "拓展 PS、ABS 与 SBS 树脂",
    description:
      "产品线延伸至聚苯乙烯、ABS 树脂与 SBS，满足家电与电子制造企业不断增长的需求。",
  },
  {
    year: "2014",
    title: "营销网络覆盖 30 多个省市",
    description:
      "在北京、天津、石家庄、沈阳、葫芦岛、济南、青岛、郑州、赣州、武汉、重庆、成都、广东等地设立办事处与仓库。",
  },
  {
    year: "2019",
    title: "天晖电子商务物流园区投入使用",
    description:
      "投资 2 亿元人民币建成 30,000 平方米物流园区，将销售、仓储、研发与售后服务整合于一座园区。",
  },
  {
    year: "2019",
    title: "网络货运平台上线",
    description:
      "天晖浩骏普货技术服务后台管理系统 V1.0 在中华人民共和国国家版权局完成著作权登记。",
  },
  {
    year: "2020",
    title: "入选中国服务业企业 500 强",
    description:
      "天晖入选中国服务业企业 500 强，成为河北省“双百强”企业，并获评中国人民银行金牌诚信客户。",
  },
  {
    year: "2023",
    title: "国际贸易版图加速拓展",
    description:
      "进出口业务覆盖二十多个国家和地区，依托长期的海外合作关系持续推进。",
  },
  {
    year: "至今",
    title: "迈向一体化供应链平台",
    description:
      "天晖持续投入国际销售、数字化系统与可持续发展，从树脂贸易商逐步成长为综合供应链服务平台。",
  },
];
---

<BaseLayout
  title="发展历程"
  description="二十年间，天晖从区域树脂经销商逐步成长为一体化供应链平台。"
>
  <PageHero
    eyebrow="关于天晖"
    title="发展历程"
    description="天晖从秦皇岛的贸易公司，发展为服务全球客户的一体化树脂供应链平台，沿途留下一个个里程碑。"
    breadcrumb={[
      { label: "首页", href: "/zh/" },
      { label: "关于我们", href: "/zh/about/company-profile/" },
      { label: "发展历程" },
    ]}
    image={images.teamGroupPhoto}
    imagePosition="center 30%"
  />

  <SubNav links={aboutLinksZh} currentHref="/zh/about/our-history/" label="栏目导航" />

  <!-- SECTION: Timeline -->
  <section id="timeline" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-4 lg:sticky lg:top-28">
          <SectionHeading
            eyebrow="发展时间线"
            title="二十年专注成长"
            description="下面每一个里程碑，都是天晖从树脂贸易商向垂直一体化供应链伙伴转型的一步。"
          />
        </div>
        <ol class="relative space-y-12 border-l border-slate-200 pl-8 lg:col-span-8">
          {
            timeline.map((event) => (
              <li class="relative">
                <span class="absolute -left-[39px] mt-2 inline-flex size-4 items-center justify-center rounded-full border-4 border-white bg-brand-600 shadow" />
                <p class="text-xs font-semibold tracking-[0.2em] text-brand-700 uppercase">
                  {event.year}
                </p>
                <h3 class="mt-2 text-xl font-semibold text-slate-900">
                  {event.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-600">
                  {event.description}
                </p>
              </li>
            ))
          }
        </ol>
      </div>
    </Container>
  </section>

  <!-- SECTION: Team photo strip -->
  <section id="team-photo" class="bg-slate-50 py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.teamGroupPhoto}
              alt="天晖集团 2023 年团建合影"
              class="aspect-[16/9] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="一个天晖"
            title="由每天坚守岗位的人共同铸就"
            description="历史上的每一个里程碑，都离不开销售、物流、研发与售后等岗位同事的付出，也离不开选择与我们共同成长的伙伴与客户。"
          />
          <a
            href="/zh/about/tianhui-values/"
            class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 hover:text-brand-800"
          >
            我们的价值观
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
