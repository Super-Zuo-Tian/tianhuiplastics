---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import PageHero from "../../../components/PageHero.astro";
import SubNav from "../../../components/SubNav.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import InquiryCTA from "../../../components/InquiryCTA.astro";
import { aboutLinksZh } from "../../../data/navSections";
import { images } from "../../../data/images";

const values = [
  {
    title: "诚信为本",
    description:
      "以言行一致赢得供应商、伙伴与客户的长期信任，说到做到。",
  },
  {
    title: "以和为贵",
    description:
      "在公司内部与价值链上下游，努力营造合作共赢的关系，而非零和博弈。",
  },
  {
    title: "信誉至上",
    description:
      "每一笔交易均有据可查，每一批货物均可追溯。我们不为短期利益而牺牲信誉。",
  },
  {
    title: "开拓进取",
    description:
      "拥抱变化、投入新能力，从数字化平台到国际贸易，持续探索更好地服务客户的方式。",
  },
];

const principles = [
  {
    label: "使命",
    text: "让塑料树脂对全球加工企业与品牌商而言更可靠、更透明、更易获取。",
  },
  {
    label: "愿景",
    text: "在国内乃至全球塑料行业供应链服务领域，成为值得信赖、具有影响力的企业。",
  },
  {
    label: "服务承诺",
    text: "及时响应、透明报价、稳定交付、持续改进。",
  },
];
---

<BaseLayout
  title="天晖价值观"
  description="诚信为本、以和为贵、信誉至上、开拓进取——天晖的企业文化贯穿于日常的客户与伙伴服务之中。"
>
  <PageHero
    eyebrow="关于天晖"
    title="诚信为本 · 以和为贵 · 信誉至上 · 开拓进取"
    description="天晖的企业文化可以用几句话概括，但它体现在每一次报价、每一批货物与每一段客户关系之中。"
    breadcrumb={[
      { label: "首页", href: "/zh/" },
      { label: "关于我们", href: "/zh/about/company-profile/" },
      { label: "天晖价值观" },
    ]}
    image={images.lobbyLogoWall}
    imagePosition="center"
  />

  <SubNav links={aboutLinksZh} currentHref="/zh/about/tianhui-values/" label="栏目导航" />

  <!-- SECTION: Group culture statement -->
  <section id="statement" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-6">
          <SectionHeading
            eyebrow="企业文化"
            title="诚信为本、以和为贵、信誉至上、开拓进取的文化"
          />
          <p class="mt-8 text-base leading-7 text-slate-700">
            面向未来，天晖集团将不忘初心，继续秉持
            <strong class="font-semibold">“诚信为本、以和为贵、信誉至上、开拓进取”</strong>的企业文化。
          </p>
          <p class="mt-4 text-base leading-7 text-slate-700">
            我们将在塑料领域深耕细作、稳步拓展，努力将自身打造成为塑料行业供应链服务领域
            值得信赖的企业。
          </p>
        </div>
        <div class="lg:col-span-6">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.lobbyLogoWall}
              alt="天晖集团形象墙——凝心聚力，创造辉煌"
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: Mission / Vision / Pledge -->
  <section id="principles" class="bg-slate-50 py-24 sm:py-32">
    <Container>
      <SectionHeading
        eyebrow="宗旨"
        title="我们坚持什么"
        description="天晖的宗旨不止于树脂贸易，更在于成为为客户简化采购的可信赖伙伴。"
      />
      <div class="mt-16 grid gap-6 md:grid-cols-3">
        {
          principles.map((p) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
              <p class="text-xs font-semibold tracking-[0.2em] text-brand-700 uppercase">
                {p.label}
              </p>
              <p class="mt-4 text-base leading-7 text-slate-800">{p.text}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Four values -->
  <section id="values" class="bg-white py-24 sm:py-32">
    <Container>
      <SectionHeading
        eyebrow="核心价值观"
        title="指导我们决策的四个准则"
        description="从一袋料的报价到一年期的合同管理，这些价值观定义了我们的运营方式。"
      />
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          values.map((value, idx) => (
            <article class="group relative overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm transition hover:-translate-y-1 hover:bg-white hover:shadow-lg">
              <span class="text-5xl font-semibold tracking-tight text-brand-100 group-hover:text-brand-200">
                0{idx + 1}
              </span>
              <h3 class="mt-3 text-lg font-semibold text-slate-900">
                {value.title}
              </h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                {value.description}
              </p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Team photo -->
  <section id="team" class="bg-slate-50 py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.teamBuilding}
              alt="天晖集团在总部前开展团建活动"
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="价值观的践行"
            title="由团队每日践行"
            description="我们的员工把价值观转化为日常行动：数小时内回复报价、反复核对单据、对每一批货物尽职尽责，并把客户视为长期伙伴。"
          />
        </div>
      </div>
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
