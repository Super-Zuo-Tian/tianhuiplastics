---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import PageHero from "../../../components/PageHero.astro";
import SubNav from "../../../components/SubNav.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import InquiryCTA from "../../../components/InquiryCTA.astro";
import { aboutLinksZh } from "../../../data/navSections";
import { images } from "../../../data/images";

const certifications = [
  {
    title: "道路运输经营许可证",
    description:
      "由中华人民共和国交通运输部核发，认定天晖为持牌网络货运经营者。",
    issuer: "中华人民共和国交通运输部",
    image: images.certTransport,
  },
  {
    title: "计算机软件著作权登记证书",
    description:
      "由中华人民共和国国家版权局颁发，登记软件为“天晖浩骏普货技术服务后台管理系统 V1.0”。",
    issuer: "中华人民共和国国家版权局",
    image: images.certSoftware,
  },
];

const awards = [
  "中国服务业企业 500 强（2020）",
  "京津冀百强企业",
  "京津冀服务业百强企业",
  "河北省民营企业百强",
  "河北省服务业百强企业",
  "河北省委重点支持企业",
  "中国人民银行金牌诚信客户",
];

const reports = [
  {
    title: "出厂检验报告（COA）",
    description:
      "每批货物均附带 COA，涵盖熔融指数、密度、灰分等指标。",
  },
  {
    title: "原厂质检报告",
    description:
      "可应客户要求提供上游石化生产企业的原厂质检报告。",
  },
  {
    title: "第三方检验",
    description:
      "可应客户要求接受 SGS、BV、CCIC 等第三方检验，以符合国际采购标准。",
  },
];
---

<BaseLayout
  title="资质与荣誉"
  description="记录天晖在质量、合规与可追溯方面投入的认证、奖项与质量报告。"
>
  <PageHero
    eyebrow="关于天晖"
    title="资质与荣誉"
    description="质量与合规并非口号，而是体现在我们的认证、奖项与客户反馈之中。"
    breadcrumb={[
      { label: "首页", href: "/zh/" },
      { label: "关于我们", href: "/zh/about/company-profile/" },
      { label: "资质与荣誉" },
    ]}
    image={images.top500Celebration}
    imagePosition="center 35%"
  />

  <SubNav links={aboutLinksZh} currentHref="/zh/about/awards-recognitions/" label="栏目导航" />

  <!-- SECTION: Featured awards strip -->
  <section id="featured" class="border-b border-slate-200 bg-white py-12">
    <Container>
      <p class="text-xs font-semibold tracking-[0.2em] text-brand-700 uppercase">
        重点荣誉
      </p>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {
          awards.map((a) => (
            <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-800">
              {a}
            </li>
          ))
        }
      </ul>
    </Container>
  </section>

  <!-- SECTION: Top 500 photo + intro -->
  <section id="top500" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.top500Celebration}
              alt="天晖集团庆祝入选中国服务业企业 500 强"
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="中国服务业企业 500 强"
            title="跻身中国服务业企业行列"
            description="2020 年，天晖入选中国服务业企业 500 强——这一里程碑反映了公司的规模、服务质量以及对塑料供应链行业的贡献。"
          />
          <p class="mt-6 text-base leading-7 text-slate-700">
            同年，天晖还入选河北省民营企业百强与河北省服务业百强（“双百强”企业），
            并获评中国人民银行金牌诚信客户。
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: Certificates -->
  <section id="certificates" class="bg-slate-50 py-24 sm:py-32">
    <Container>
      <SectionHeading
        eyebrow="证书与许可"
        title="持牌经营，质量有据可查"
      />
      <div class="mt-16 grid gap-8 lg:grid-cols-2">
        {
          certifications.map((cert) => (
            <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
              <div class="aspect-[4/3] w-full overflow-hidden bg-slate-100">
                <img
                  src={cert.image}
                  alt={cert.title}
                  class="size-full object-contain p-6"
                  loading="lazy"
                />
              </div>
              <div class="p-8">
                <h3 class="text-lg font-semibold text-slate-900">{cert.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{cert.description}</p>
                <p class="mt-4 text-xs font-semibold tracking-[0.18em] text-slate-500 uppercase">
                  颁发单位 · {cert.issuer}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Reports -->
  <section id="reports" class="bg-white py-24 sm:py-32">
    <Container>
      <SectionHeading
        eyebrow="质量报告"
        title="为每批货物提供完整资料"
        description="我们提供国际买家所需的资料，便于您的质检、报关与采购团队高效推进。"
      />
      <div class="mt-16 grid gap-6 md:grid-cols-3">
        {
          reports.map((rep) => (
            <article class="rounded-3xl border border-slate-200 bg-slate-50 p-8">
              <h3 class="text-base font-semibold text-slate-900">{rep.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{rep.description}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
