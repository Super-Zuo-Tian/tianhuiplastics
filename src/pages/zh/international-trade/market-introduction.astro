---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import PageHero from "../../../components/PageHero.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import InquiryCTA from "../../../components/InquiryCTA.astro";
import { images } from "../../../data/images";

const exportMarkets = [
  { region: "东南亚", countries: ["越南", "印度尼西亚", "新加坡"] },
  { region: "南亚", countries: ["巴基斯坦", "孟加拉国", "印度"] },
  { region: "中东与土耳其", countries: ["土耳其"] },
  { region: "非洲与大洋洲", countries: ["坦桑尼亚", "澳大利亚"] },
  { region: "美洲", countries: ["南美洲（多国）"] },
];

const importMarkets = [
  "阿拉伯联合酋长国",
  "卡塔尔",
  "美国",
  "韩国",
  "伊朗",
];

const services = [
  {
    title: "FOB / CFR / CIF 报价",
    description:
      "根据目的港与物流安排灵活选择贸易术语。",
  },
  {
    title: "单证支持",
    description:
      "由团队准备 COA、MSDS、原产地证、装箱单、商业发票等出口单证。",
  },
  {
    title: "集装箱与整柜装载",
    description:
      "可在物流园区进行 20'GP 与 40'HQ 装柜，并提供港口装柜及吨袋等选项。",
  },
  {
    title: "检验与合规",
    description:
      "可应要求安排 SGS / BV / CCIC 第三方检验，符合目的市场要求。",
  },
];
---

<BaseLayout
  title="国际贸易 — 市场介绍"
  description="天晖的国际贸易业务覆盖多个国家和地区。了解我们的出口目的地、进口来源与出口服务。"
>
  <PageHero
    eyebrow="国际贸易"
    title="市场介绍"
    description="进出口业务覆盖多个国家和地区，依托双语外贸团队与一体化供应链。"
    breadcrumb={[
      { label: "首页", href: "/zh/" },
      { label: "国际贸易" },
      { label: "市场介绍" },
    ]}
    image={images.citySkyline}
    imagePosition="center 60%"
  />

  <!-- SECTION: Overview -->
  <section id="overview" class="bg-white py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="概览"
        title="覆盖全球的树脂贸易网络"
        description="天晖的国际贸易业务将国内石化生产企业与全球的加工企业及贸易商连接起来。出口业务覆盖东南亚、南亚、中东、非洲、大洋洲与美洲；进口则引入来自阿联酋、卡塔尔、美国、韩国与伊朗的部分专用牌号。"
      />
    </Container>
  </section>

  <!-- SECTION: Export markets -->
  <section id="exports" class="bg-slate-50 py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="出口市场"
        title="天晖树脂的出口去向"
        description="天晖向以下地区的加工企业与贸易商出口 PE、PP、PS 与 ABS 树脂。"
      />
      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          exportMarkets.map((market) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
              <h3 class="text-base font-semibold text-slate-900">{market.region}</h3>
              <ul class="mt-4 flex flex-wrap gap-2">
                {market.countries.map((c) => (
                  <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                    {c}
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Import sources -->
  <section id="imports" class="bg-white py-24 sm:py-28">
    <Container>
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-6">
          <SectionHeading
            eyebrow="进口来源"
            title="国际化采购的专用树脂"
            description="在国内供应网络之外，天晖进口专用与高性能树脂牌号，以满足特定客户需求。"
          />
        </div>
        <div class="lg:col-span-6">
          <ul class="grid gap-3 sm:grid-cols-2">
            {
              importMarkets.map((country) => (
                <li class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm font-medium text-slate-800">
                  <span class="inline-flex size-2 rounded-full bg-brand-600" />
                  {country}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: Trade services -->
  <section id="services" class="bg-slate-50 py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="贸易服务"
        title="外贸团队能为您做什么"
        description="从首次询价到最终提单，我们的外贸团队处理每一个环节，让您的采购运作顺畅。"
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          services.map((service) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
              <h3 class="text-base font-semibold text-slate-900">{service.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{service.description}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Logistics highlight -->
  <section id="logistics" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-6">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.trucks}
              alt="天晖物流车队——长途运输货车"
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-6">
          <SectionHeading
            eyebrow="物流"
            title="从中国主要港口发货"
            description="依托天津、青岛、太仓、宁波等国内核心港口发货;拥有专业的物流运营团队，成熟网络货运平台全国布局仓储备货网点，支持就近快速调货配送，发货高效、运力稳定。"
          />
          <a
            href="/zh/about/factory-capability/"
            class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 hover:text-brand-800"
          >
            走进物流园区
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <InquiryCTA
    title="需要将树脂送达您的港口？"
    description="请告知牌号、数量、包装与目的地，我们将在一个工作日内回复 CFR 或 CIF 报价。"
  />
</BaseLayout>
