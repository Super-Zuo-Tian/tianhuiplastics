---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import PageHero from "../../../components/PageHero.astro";
import SubNav from "../../../components/SubNav.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import NewsCard from "../../../components/NewsCard.astro";
import InquiryCTA from "../../../components/InquiryCTA.astro";
import { newsLinksZh } from "../../../data/navSections";
import { getPostsByCategory } from "../../../data/news";
import { images } from "../../../data/images";

const posts = getPostsByCategory("global");
---

<BaseLayout
  title="全球资讯"
  description="天晖整理的塑料树脂市场动态与全球行业资讯。"
>
  <PageHero
    eyebrow="新闻资讯"
    title="全球资讯"
    description="来自我们所交易树脂市场的市场动态与行业资讯。"
    breadcrumb={[
      { label: "首页", href: "/zh/" },
      { label: "新闻资讯" },
      { label: "全球资讯" },
    ]}
    image={images.citySkyline}
    imagePosition="center"
  />

  <SubNav links={newsLinksZh} currentHref="/zh/news/global-news/" label="栏目导航" />

  <section id="global-news" class="bg-white py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="业内"
        title="来自世界各地的行业动态"
        description="精选与 PE、PP、PS、ABS 市场相关的行业新闻、市场动态与政策进展。"
      />
      {
        posts.length > 0 ? (
          <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {posts.map((post) => (
              <NewsCard post={post} uniform />
            ))}
          </div>
        ) : (
          <p class="mt-12 rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-12 text-center text-sm text-slate-500">
            暂无全球资讯。
          </p>
        )
      }
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
