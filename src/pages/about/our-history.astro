---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import PageHero from "../../components/PageHero.astro";
import SubNav from "../../components/SubNav.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import InquiryCTA from "../../components/InquiryCTA.astro";
import { aboutLinks } from "../../data/navSections";
import { images } from "../../data/images";

const timeline = [
  {
    year: "2004",
    title: "TIANHUI is founded in Qinhuangdao",
    description:
      "The company starts as a regional plastic resin distributor focused on PE and PP grades, building its first long-term partnerships with Chinese petrochemical producers.",
  },
  {
    year: "2010",
    title: "Expansion into PS, ABS and SBS resins",
    description:
      "TIANHUI's product portfolio extends to polystyrene, ABS resin and SBS, supporting growing demand from appliance and electronics manufacturers.",
  },
  {
    year: "2014",
    title: "Marketing network covers 30+ provinces",
    description:
      "Offices and warehouses open across Beijing, Tianjin, Shijiazhuang, Shenyang, Huludao, Jinan, Qingdao, Zhengzhou, Ganzhou, Wuhan, Chongqing, Chengdu, Guangdong and more.",
  },
  {
    year: "2019",
    title: "Tianhui E-commerce Logistics Park commissioned",
    description:
      "A CNY 200 million investment delivers the 30,000 m² logistics park, consolidating sales, warehousing, R&D and after-sales services into one campus.",
  },
  {
    year: "2019",
    title: "Network freight platform launches",
    description:
      "The Tianhui Haojun General Freight Technical Service Backend Management System V1.0 is registered with the National Copyright Administration of the PRC.",
  },
  {
    year: "2020",
    title: "Top 500 Chinese Service Enterprises",
    description:
      "TIANHUI is named among China's Top 500 Service Enterprises, becomes a 'double top 100' Hebei enterprise and a Gold Medal Trusted Customer of the People's Bank of China.",
  },
  {
    year: "2023",
    title: "International trade footprint accelerates",
    description:
      "Active export and import operations reach more than 20 countries across four continents, supported by long-term overseas partnerships.",
  },
  {
    year: "Today",
    title: "Toward an integrated supply chain platform",
    description:
      "TIANHUI continues to invest in international sales, digital systems and sustainability, evolving from a resin trader into a comprehensive supply chain service platform.",
  },
];
---

<BaseLayout
  title="Our History"
  description="Two decades of TIANHUI's evolution from a regional resin distributor into an integrated supply chain platform."
>
  <PageHero
    eyebrow="About TIANHUI"
    title="Our History"
    description="Milestones along TIANHUI's journey from a Qinhuangdao trading house to an integrated resin supply chain platform serving global customers."
    breadcrumb={[
      { label: "Home", href: "/" },
      { label: "About", href: "/about/company-profile/" },
      { label: "Our History" },
    ]}
    image={images.teamGroupPhoto}
    imagePosition="center 30%"
  />

  <SubNav links={aboutLinks} currentHref="/about/our-history/" />

  <!-- SECTION: Timeline -->
  <section id="timeline" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-4 lg:sticky lg:top-28">
          <SectionHeading
            eyebrow="Timeline"
            title="Twenty years of focused growth"
            description="Each milestone below marks a step in TIANHUI's transformation from a resin trader into a vertically integrated supply chain partner."
          />
        </div>
        <ol class="relative space-y-12 border-l border-slate-200 pl-8 lg:col-span-8">
          {
            timeline.map((event) => (
              <li class="relative">
                <span class="absolute -left-[39px] mt-2 inline-flex size-4 items-center justify-center rounded-full border-4 border-white bg-brand-600 shadow" />
                <p class="text-xs font-semibold tracking-[0.2em] text-brand-700 uppercase">
                  {event.year}
                </p>
                <h3 class="mt-2 text-xl font-semibold text-slate-900">
                  {event.title}
                </h3>
                <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-600">
                  {event.description}
                </p>
              </li>
            ))
          }
        </ol>
      </div>
    </Container>
  </section>

  <!-- SECTION: Team photo strip -->
  <section id="team-photo" class="bg-slate-50 py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.teamGroupPhoto}
              alt="TIANHUI Group annual team-building photo 2023"
              class="aspect-[16/9] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="One TIANHUI"
            title="Built by the people who show up every day"
            description="Every milestone in our history was made possible by the dedication of our colleagues across sales, logistics, R&D and after-sales — and by the partners and customers who chose to grow with us."
          />
          <a
            href="/about/tianhui-values/"
            class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 hover:text-brand-800"
          >
            Our values
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
