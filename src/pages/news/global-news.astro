---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import PageHero from "../../components/PageHero.astro";
import SubNav from "../../components/SubNav.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import NewsCard from "../../components/NewsCard.astro";
import InquiryCTA from "../../components/InquiryCTA.astro";
import { newsLinks } from "../../data/navSections";
import { getPostsByCategory } from "../../data/news";
import { images } from "../../data/images";

const posts = getPostsByCategory("global");
---

<BaseLayout
  title="Global News"
  description="Plastic resin market intelligence and global industry news curated by TIANHUI."
>
  <PageHero
    eyebrow="News"
    title="Global News"
    description="Market intelligence and industry updates from the resin markets we trade in."
    breadcrumb={[
      { label: "Home", href: "/" },
      { label: "News" },
      { label: "Global News" },
    ]}
    image={images.citySkyline}
    imagePosition="center"
  />

  <SubNav links={newsLinks} currentHref="/news/global-news/" />

  <section id="global-news" class="bg-white py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="Industry"
        title="Industry updates from around the world"
        description="Curated industry news, market intelligence and policy developments relevant to PE, PP, PS and ABS markets."
      />
      {
        posts.length > 0 ? (
          <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {posts.map((post) => (
              <NewsCard post={post} uniform />
            ))}
          </div>
        ) : (
          <p class="mt-12 rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-12 text-center text-sm text-slate-500">
            No global news entries yet.
          </p>
        )
      }
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
