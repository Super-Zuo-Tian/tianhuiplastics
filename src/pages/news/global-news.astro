---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import PageHero from "../../components/PageHero.astro";
import SubNav from "../../components/SubNav.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import NewsCard from "../../components/NewsCard.astro";
import InquiryCTA from "../../components/InquiryCTA.astro";
import { newsLinks } from "../../data/navSections";
import { getPostsByCategory } from "../../data/news";
import { images } from "../../data/images";

const posts = getPostsByCategory("global");
const [featured, ...rest] = posts;
---

<BaseLayout
  title="Global News"
  description="Plastic resin market intelligence and global industry news curated by TIANHUI."
>
  <PageHero
    eyebrow="News"
    title="Global News"
    description="Market intelligence and industry updates from the resin markets we trade in."
    breadcrumb={[
      { label: "Home", href: "/" },
      { label: "News" },
      { label: "Global News" },
    ]}
    image={images.citySkyline}
    imagePosition="center"
  />

  <SubNav links={newsLinks} currentHref="/news/global-news/" />

  <!-- SECTION: Featured -->
  <section id="featured" class="bg-white py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="Latest"
        title="Industry updates from around the world"
        description="Curated industry news, market intelligence and policy developments relevant to PE, PP, PS and ABS markets."
      />
      {
        featured && (
          <div class="mt-12 grid gap-6 lg:grid-cols-3">
            <NewsCard post={featured} featured />
            {rest.slice(0, 2).map((post) => (
              <NewsCard post={post} />
            ))}
          </div>
        )
      }
      {
        !featured && (
          <p class="mt-12 rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-12 text-center text-sm text-slate-500">
            No global news entries yet. Add posts in <code>src/data/news.ts</code>.
          </p>
        )
      }
    </Container>
  </section>

  <!-- SECTION: Archive -->
  {
    rest.length > 2 && (
      <section id="archive" class="bg-slate-50 py-24 sm:py-28">
        <Container>
          <SectionHeading eyebrow="Archive" title="More global news" />
          <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {rest.slice(2).map((post) => (
              <NewsCard post={post} />
            ))}
          </div>
        </Container>
      </section>
    )
  }

  <InquiryCTA />
</BaseLayout>
