---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/Container.astro";
import PageHero from "../../../components/PageHero.astro";
import InquiryCTA from "../../../components/InquiryCTA.astro";
import { newsPosts } from "../../../data/news";
import { getArticleContentOrFallback } from "../../../data/newsContent";
import { images } from "../../../data/images";

export async function getStaticPaths() {
  return newsPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const article = getArticleContentOrFallback(post, "en");

const categoryLabel = post.category === "company" ? "Company News" : "Global News";
const categoryHref = post.category === "company" ? "/news/company-news/" : "/news/global-news/";
const dateLabel = new Date(post.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const related = newsPosts
  .filter((p) => p.slug !== post.slug && p.category === post.category)
  .slice(0, 3);

const heroImage = post.cover ?? (post.category === "company" ? images.annualMeeting : images.citySkyline);
---

<BaseLayout title={post.title} description={post.excerpt}>
  <PageHero
    eyebrow={categoryLabel}
    title={post.title}
    description={post.excerpt}
    breadcrumb={[
      { label: "Home", href: "/" },
      { label: "News" },
      { label: categoryLabel, href: categoryHref },
    ]}
    image={heroImage}
    imagePosition="center 35%"
  >
    <p class="mt-6 text-sm text-slate-300">
      Published on <time datetime={post.date}>{dateLabel}</time>
    </p>
  </PageHero>

  <section id="article" class="bg-white py-20 sm:py-24">
    <Container class="max-w-3xl">
      <div
        class="prose prose-slate prose-lg max-w-none text-slate-700 prose-img:rounded-2xl prose-img:shadow-md"
        set:html={article.contentHtml}
      />

      {
        post.tags && post.tags.length > 0 && (
          <div class="mt-12 border-t border-slate-200 pt-6">
            <p class="text-xs font-semibold tracking-wider text-slate-500 uppercase">
              Tags
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <li class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                  {tag}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <div class="mt-12 flex flex-wrap items-center gap-4">
        <a
          href={categoryHref}
          class="inline-flex items-center gap-2 rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-900"
        >
          <span aria-hidden="true">&larr;</span>
          Back to {categoryLabel}
        </a>
      </div>
    </Container>
  </section>

  <!-- SECTION: Related -->
  {
    related.length > 0 && (
      <section id="related" class="bg-slate-50 py-20 sm:py-24">
        <Container>
          <h2 class="text-2xl font-semibold text-slate-900">Related stories</h2>
          <div class="mt-8 grid gap-6 md:grid-cols-3">
            {related.map((p) => (
              <a
                href={`/news/posts/${p.slug}/`}
                class="block rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md"
              >
                <span class="text-xs font-semibold tracking-wider text-brand-700 uppercase">
                  {p.category === "company" ? "Company News" : "Global News"}
                </span>
                <h3 class="mt-3 text-base font-semibold text-slate-900">{p.title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-600">{p.excerpt}</p>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )
  }

  <InquiryCTA />
</BaseLayout>
