---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import PageHero from "../../components/PageHero.astro";
import SubNav from "../../components/SubNav.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import NewsCard from "../../components/NewsCard.astro";
import InquiryCTA from "../../components/InquiryCTA.astro";
import { newsLinks } from "../../data/navSections";
import { getPostsByCategory } from "../../data/news";
import { images } from "../../data/images";

const posts = getPostsByCategory("company");
const [featured, ...rest] = posts;
---

<BaseLayout
  title="Company News"
  description="Corporate updates, exhibition appearances and partnership announcements from TIANHUI Group."
>
  <PageHero
    eyebrow="News"
    title="Company News"
    description="Corporate updates, exhibition appearances and partnership announcements from TIANHUI Group."
    breadcrumb={[
      { label: "Home", href: "/" },
      { label: "News" },
      { label: "Company News" },
    ]}
    image={images.annualMeeting}
    imagePosition="center 30%"
  />

  <SubNav links={newsLinks} currentHref="/news/company-news/" />

  <!-- SECTION: Featured -->
  <section id="featured" class="bg-white py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="Latest"
        title="What's new at TIANHUI"
        description="The most recent news from our corporate, exhibition and partnership activities."
      />
      {
        featured && (
          <div class="mt-12 grid gap-6 lg:grid-cols-3">
            <NewsCard post={featured} featured />
            {rest.slice(0, 2).map((post) => (
              <NewsCard post={post} />
            ))}
          </div>
        )
      }
    </Container>
  </section>

  <!-- SECTION: Archive -->
  {
    rest.length > 2 && (
      <section id="archive" class="bg-slate-50 py-24 sm:py-28">
        <Container>
          <SectionHeading
            eyebrow="Archive"
            title="More company news"
          />
          <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {rest.slice(2).map((post) => (
              <NewsCard post={post} />
            ))}
          </div>
        </Container>
      </section>
    )
  }

  <InquiryCTA />
</BaseLayout>
