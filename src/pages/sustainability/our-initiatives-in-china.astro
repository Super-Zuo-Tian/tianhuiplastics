---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import PageHero from "../../components/PageHero.astro";
import SubNav from "../../components/SubNav.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import InquiryCTA from "../../components/InquiryCTA.astro";
import { sustainabilityLinks } from "../../data/navSections";
import { images } from "../../data/images";

const initiatives = [
  {
    title: "Plastic Recycling Awareness",
    description:
      "Working with local schools and communities to raise awareness of responsible plastic use, classification and recycling.",
  },
  {
    title: "Charity & Education Support",
    description:
      "Annual donations and scholarship programs supporting students and educators in our home region of Qinhuangdao.",
  },
  {
    title: "Disaster Relief Contributions",
    description:
      "Provision of materials and donations during regional natural disasters, in coordination with local authorities and charities.",
  },
  {
    title: "Community Sport & Culture",
    description:
      "Sponsoring community sport events and cultural programs that strengthen local connections and well-being.",
  },
];

const focusAreas = [
  "Reducing transport empty mileage through our network freight platform",
  "Optimising packaging to minimise waste at customer sites",
  "Encouraging the use of recyclable resin grades where feasible",
  "Working with upstream partners on lower-carbon production routes",
];
---

<BaseLayout
  title="Our Initiatives in China"
  description="TIANHUI's public welfare projects and sustainability initiatives in China — combining education, community and environmental work."
>
  <PageHero
    eyebrow="Sustainability"
    title="Our Initiatives in China"
    description="Since its establishment, TIANHUI has donated over 3 million RMB to charitable causes — combining economic assistance, material support and spiritual encouragement."
    breadcrumb={[
      { label: "Home", href: "/" },
      { label: "Sustainability" },
      { label: "Our Initiatives in China" },
    ]}
    image={images.teamBuilding}
    imagePosition="center 35%"
  />

  <SubNav links={sustainabilityLinks} currentHref="/sustainability/our-initiatives-in-china/" />

  <!-- SECTION: Intro -->
  <section id="intro" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <SectionHeading
            eyebrow="Commitment"
            title="Doing business responsibly, in the regions where we operate"
          />
          <p class="mt-8 text-base leading-7 text-slate-700">
            TIANHUI Group has always regarded assuming greater social
            responsibility as an important corporate mission, actively
            participating in public welfare undertakings and fulfilling its
            corporate social responsibility. This includes not only economic
            assistance and material support but also spiritual encouragement
            and support.
          </p>
          <p class="mt-4 text-base leading-7 text-slate-700">
            Since its establishment, the company has donated over 3 million
            RMB to charitable causes. We will continue to support public
            welfare undertakings and contribute our due strength to the
            country to the best of our ability.
          </p>
        </div>
        <div class="lg:col-span-5">
          <div class="overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.teamGroupPhoto}
              alt="TIANHUI Group team building"
              class="aspect-[4/5] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: Initiative cards -->
  <section id="initiatives" class="bg-slate-50 py-24 sm:py-28">
    <Container>
      <SectionHeading
        eyebrow="Initiatives"
        title="Where we focus our efforts"
        description="A snapshot of selected initiatives. Detailed reports and partner organisations available on request."
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2">
        {
          initiatives.map((item) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
              <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Focus areas -->
  <section id="focus" class="bg-white py-24 sm:py-28">
    <Container>
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="Operational Focus"
            title="Practical, measurable improvements"
            description="Our sustainability work also extends to how we run our daily business — from logistics efficiency to packaging optimisation."
          />
        </div>
        <ul class="space-y-4 text-base leading-7 text-slate-700 lg:col-span-7">
          {
            focusAreas.map((area) => (
              <li class="flex gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <span class="mt-2 size-2 flex-none rounded-full bg-brand-600" />
                <span>{area}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </section>

  <InquiryCTA
    title="Want to learn more about our sustainability work?"
    description="We are happy to share detailed reports and discuss collaboration opportunities with NGOs, suppliers and customers."
    primaryLabel="Contact our team"
  />
</BaseLayout>
