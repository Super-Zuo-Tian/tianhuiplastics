---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import SectionHeading from "../components/SectionHeading.astro";
import InquiryCTA from "../components/InquiryCTA.astro";
import { productFamilies } from "../data/products";
import { newsPosts } from "../data/news";
import { site } from "../data/site";
import { images } from "../data/images";

const stats = [
  { value: "2004", label: "Established in Qinhuangdao" },
  { value: "~1,000", label: "Resin grades in portfolio" },
  { value: "30,000 m²", label: "Tianhui Logistics Park" },
  { value: "300+", label: "Warehouses nationwide" },
  { value: "30+", label: "Provinces & municipalities" },
  { value: "20+", label: "Export destinations" },
];

const honours = [
  "Top 500 Chinese Service Enterprises",
  "Top 100 Enterprises · Beijing-Tianjin-Hebei",
  "Top 100 Service Enterprises · Beijing-Tianjin-Hebei",
  "Top 100 Enterprises · Hebei Province",
  "Top 100 Service Enterprises · Hebei Province",
];

const services = [
  {
    title: "Plastic raw material supply",
    description:
      "PE, PP, ABS, PS, SBS and other resin series — nearly 1,000 grades in stock, meeting the demands of multiple industries.",
  },
  {
    title: "Stable and reliable channels",
    description:
      "Long-term agency and strategic partnerships with PetroChina, Sinopec, China Coal, Yanchang Petroleum and Baofeng Energy.",
  },
  {
    title: "Nationwide warehousing",
    description:
      "Offices and over 300 warehouses across 30+ provinces and municipalities enable local distribution and lower logistics costs.",
  },
  {
    title: "Integrated supply chain",
    description:
      "Full-chain services: procurement, warehousing, logistics, distribution and after-sales — sharing resources and information.",
  },
  {
    title: "International trade services",
    description:
      "Import & export agency, international procurement and cross-border logistics, helping customers expand global markets.",
  },
  {
    title: "Customised solutions & R&D",
    description:
      "Tailored product solutions, application guidance and R&D support based on each customer's production process.",
  },
  {
    title: "Network freight & logistics",
    description:
      "Backed by the group's logistics park and digital network freight platform, enabling transparency and cost optimisation.",
  },
  {
    title: "7×24 customer service",
    description:
      "Always-on customer service for orders, logistics and after-sales — keeping cooperation smooth and worry-free.",
  },
];

const partners = [
  "PetroChina (CNPC)",
  "Sinopec",
  "China National Coal Group",
  "Shaanxi Yanchang New Energy",
  "Yanchang Petroleum (Hubei / Shanghai / Tianjin)",
  "Ningxia Baofeng Energy Group",
  "North China Huajin Chemical",
  "Shandong Dongfang Hongye Chemical",
];

const recentNews = newsPosts.slice(0, 3);
---

<BaseLayout description={site.description}>
  <!-- SECTION: Hero (full-bleed photo of TIANHUI Logistics Park) -->
  <section
    id="hero"
    class="relative isolate flex min-h-[78vh] items-center overflow-hidden bg-slate-950"
  >
    <img
      src={images.building1}
      alt="TIANHUI Logistics Park headquarters building"
      class="absolute inset-0 -z-20 size-full object-cover"
      loading="eager"
    />
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-r from-slate-950/85 via-slate-950/55 to-slate-950/10"
    >
    </div>
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-t from-slate-950/70 via-transparent to-slate-950/30"
    >
    </div>
    <Container class="relative py-32">
      <div class="max-w-3xl">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-medium tracking-[0.2em] text-brand-200 uppercase backdrop-blur"
        >
          <span class="size-1.5 rounded-full bg-brand-400"></span>
          Plastic Resins · Supply Chain · Network Freight
        </span>
        <h1 class="mt-8 text-5xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl">
          A diversified enterprise<br />building leadership in plastic
          supply chain services.
        </h1>
        <p class="mt-8 max-w-2xl text-lg leading-8 text-slate-200 sm:text-xl">
          Mainly engaged in the sales of plastic raw materials, TIANHUI is
          dedicated to becoming a leader in the supply chain services of the
          plastic industry — serving converters and traders across China and
          more than twenty countries worldwide.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href="/contact/"
            class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3.5 text-sm font-semibold text-slate-900 shadow-sm transition hover:bg-slate-100"
          >
            Request a Quotation
            <span aria-hidden="true">&rarr;</span>
          </a>
          <a
            href="/products/"
            class="inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            Browse Resin Catalogue
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: Stats strip -->
  <section id="stats" class="border-b border-slate-200 bg-white py-16 sm:py-20">
    <Container>
      <dl
        class="grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-3 lg:grid-cols-6"
      >
        {
          stats.map((stat) => (
            <div>
              <dd class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
                {stat.value}
              </dd>
              <dt class="mt-2 text-sm text-slate-500">{stat.label}</dt>
            </div>
          ))
        }
      </dl>
    </Container>
  </section>

  <!-- SECTION: About the group -->
  <section id="about" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-5">
          <SectionHeading
            eyebrow="Who we are"
            title="Twenty years of plastic resin trading and supply chain expertise"
          />
          <div class="mt-8 space-y-6 text-base leading-7 text-slate-700">
            <p>
              Established in 2004 and located in Qinhuangdao, Hebei Province,
              TIANHUI Group is a diversified enterprise integrating plastic
              raw material sales and online freight services. In 2019 the
              group invested 200 million RMB to build the "Tianhui E-commerce
              Logistics Park" — a 30,000 m² campus integrating sales,
              logistics, R&D, after-sales service and supply chain management
              that today serves as our headquarters.
            </p>
            <p>
              Our main products include PE, PP, ABS, PS and SBS series
              resins with nearly 1,000 grades. With a professional marketing
              team, extensive channels and a large customer base, we provide
              full-chain marketing services and solutions to converters,
              traders and brand owners around the world.
            </p>
          </div>
          <a
            href="/about/company-profile/"
            class="mt-10 inline-flex items-center gap-2 rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-700"
          >
            About TIANHUI <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <div class="lg:col-span-7">
          <div class="relative overflow-hidden rounded-3xl shadow-xl ring-1 ring-slate-200">
            <img
              src={images.lobby1}
              alt="TIANHUI Group headquarters lobby"
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
            />
            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-t from-slate-900/30 to-transparent"
            >
            </div>
          </div>
          <ul
            class="mt-6 grid grid-cols-2 gap-3 text-sm font-medium text-slate-700 sm:grid-cols-3"
          >
            {
              honours.map((h) => (
                <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                  {h}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: Product lines -->
  <section id="products" class="bg-slate-50 py-24 sm:py-32">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-8">
        <SectionHeading
          eyebrow="Our Business"
          title="Six resin families, nearly 1,000 grades in stock"
          description="From general-purpose PS to engineering-grade ABS, TIANHUI offers a complete portfolio with consistent quality, traceable origin and on-time delivery."
        />
        <a
          href="/products/"
          class="text-sm font-semibold text-brand-700 hover:text-brand-800"
        >
          View full catalogue <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div class="mt-16 grid gap-6 lg:grid-cols-3">
        <a
          href="/products/"
          class="group relative col-span-1 row-span-2 overflow-hidden rounded-3xl bg-slate-900 shadow-lg lg:col-span-1"
        >
          <img
            src={images.resinPelletsGrid}
            alt="Plastic resin pellets"
            class="size-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/30 to-transparent"
          >
          </div>
          <div class="absolute inset-x-0 bottom-0 p-8">
            <p class="text-xs font-semibold tracking-[0.2em] text-brand-200 uppercase">
              Full portfolio
            </p>
            <h3 class="mt-3 text-2xl font-semibold text-white">
              PE · PP · PS · ABS · SBS
            </h3>
            <p class="mt-3 text-sm leading-6 text-slate-200">
              Nearly 1,000 grades sourced directly from leading Chinese
              petrochemical producers.
            </p>
          </div>
        </a>
        <ul class="contents">
          {
            productFamilies.map((family) => (
              <li>
                <a
                  href={`/products/${family.slug}/`}
                  class="group flex h-full flex-col overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
                >
                  <div
                    class:list={[
                      "relative flex h-32 items-center justify-center bg-gradient-to-br",
                      family.cover,
                    ]}
                  >
                    <span class="text-5xl font-semibold tracking-tight text-slate-800/70">
                      {family.abbreviation}
                    </span>
                  </div>
                  <div class="flex flex-1 flex-col p-6">
                    <h3 class="text-lg font-semibold text-slate-900">
                      {family.name}
                    </h3>
                    <p class="mt-3 flex-1 text-sm leading-6 text-slate-600">
                      {family.summary}
                    </p>
                    <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 group-hover:text-brand-800">
                      Explore {family.abbreviation}
                      <span aria-hidden="true">&rarr;</span>
                    </span>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </section>

  <!-- SECTION: Services -->
  <section id="services" class="bg-white py-24 sm:py-32">
    <Container>
      <SectionHeading
        eyebrow="Our Services"
        title="One-stop solution from procurement to after-sales"
        description="TIANHUI focuses on providing a comprehensive range of plastic raw materials, integrated supply chain services, specialised international trade and customised marketing support."
      />
      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          services.map((service, idx) => (
            <article class="group flex h-full flex-col rounded-3xl border border-slate-200 bg-slate-50 p-7 transition hover:-translate-y-1 hover:bg-white hover:shadow-lg">
              <span class="text-xs font-semibold tracking-[0.2em] text-brand-700 uppercase">
                0{idx + 1}
              </span>
              <h3 class="mt-4 text-base font-semibold text-slate-900">
                {service.title}
              </h3>
              <p class="mt-3 flex-1 text-sm leading-6 text-slate-600">
                {service.description}
              </p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- SECTION: Logistics park photo strip -->
  <section
    id="logistics-park"
    class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32"
  >
    <img
      src={images.building3}
      alt="Tianhui Logistics Park"
      class="absolute inset-0 -z-20 size-full object-cover opacity-30"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-slate-950/70"></div>
    <Container>
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-7">
          <SectionHeading
            eyebrow="Tianhui E-commerce Logistics Park"
            title="30,000 m² of integrated operations in Qinhuangdao"
            description="Commissioned in 2019 with a CNY 200 million investment, the park integrates sales, logistics, R&D, after-sales service and supply chain management — and serves as the group's headquarters today."
            invert
          />
          <a
            href="/about/factory-capability/"
            class="mt-10 inline-flex items-center gap-2 rounded-full border border-white/30 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            Inside the logistics park
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <ul class="grid gap-4 lg:col-span-5">
          {
            [
              ["Sales operations centre", "Bilingual export team & digital quoting"],
              ["Bulk warehousing", "Indoor/outdoor zones for each resin family"],
              ["Logistics & freight", "24/7 outbound + network freight platform"],
              ["After-sales service", "Quality follow-up for every shipment"],
            ].map(([title, desc]) => (
              <li class="rounded-2xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur">
                <p class="text-sm font-semibold text-white">{title}</p>
                <p class="mt-1 text-xs leading-5 text-slate-300">{desc}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </section>

  <!-- SECTION: Partners -->
  <section id="partners" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <SectionHeading
            eyebrow="Strategic Partners"
            title="Trusted by China's leading petrochemical producers"
            description="Over the years TIANHUI has established strong partnerships with major petrochemical companies, becoming a regional agent and strategic partner."
          />
          <a
            href="/market-marketing/long-term-strategic-partners/"
            class="mt-8 inline-flex items-center gap-2 rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-700"
          >
            Long-term partners
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2 lg:col-span-8">
          {
            partners.map((p) => (
              <li class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm font-medium text-slate-800">
                <span class="inline-flex size-2 rounded-full bg-brand-600" />
                {p}
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </section>

  <!-- SECTION: International trade highlight -->
  <section
    id="international-trade"
    class="bg-slate-50 py-24 sm:py-32"
  >
    <Container>
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
        <div class="order-2 lg:order-1 lg:col-span-7">
          <div class="overflow-hidden rounded-3xl shadow-lg ring-1 ring-slate-200">
            <img
              src={images.internationalChamber}
              alt="TIANHUI at Qinhuangdao International Chamber of Commerce"
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2 lg:col-span-5">
          <SectionHeading
            eyebrow="International Trade"
            title="A trading footprint across four continents"
            description="TIANHUI exports resins to Vietnam, Indonesia, Pakistan, Bangladesh, Singapore, Turkey, Tanzania, Australia and South America, and imports speciality grades from the UAE, Qatar, the United States, South Korea and Iran."
          />
          <a
            href="/international-trade/market-introduction/"
            class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 hover:text-brand-800"
          >
            Markets we serve <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- SECTION: News -->
  <section id="news" class="bg-white py-24 sm:py-32">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-6">
        <SectionHeading
          eyebrow="News & Updates"
          title="Latest from TIANHUI"
          description="Corporate updates, exhibitions and industry intelligence from our markets."
        />
        <a
          href="/news/company-news/"
          class="text-sm font-semibold text-brand-700 hover:text-brand-800"
        >
          View all news <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <ul class="mt-12 grid gap-6 md:grid-cols-3">
        {
          recentNews.map((post) => (
            <li>
              <a
                href={`/news/posts/${post.slug}/`}
                class="group flex h-full flex-col rounded-3xl border border-slate-200 bg-slate-50/40 p-7 transition hover:bg-white hover:shadow-md"
              >
                <span class="text-xs font-semibold tracking-[0.2em] text-brand-700 uppercase">
                  {post.category === "company" ? "Company News" : "Global News"}
                </span>
                <h3 class="mt-3 text-lg font-semibold text-slate-900 group-hover:text-brand-700">
                  {post.title}
                </h3>
                <p class="mt-3 flex-1 text-sm leading-6 text-slate-600">
                  {post.excerpt}
                </p>
                <time class="mt-6 text-xs text-slate-500" datetime={post.date}>
                  {new Date(post.date).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </a>
            </li>
          ))
        }
      </ul>
    </Container>
  </section>

  <InquiryCTA />
</BaseLayout>
