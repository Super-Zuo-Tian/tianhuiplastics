---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  invert?: boolean;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  invert = false,
} = Astro.props;

const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
const titleColor = invert ? "text-white" : "text-slate-900";
const descColor = invert ? "text-slate-300" : "text-slate-600";
const eyebrowColor = invert ? "text-brand-200" : "text-brand-700";
---

<div class:list={["max-w-3xl", alignClass]}>
  {
    eyebrow && (
      <p class:list={["text-sm font-semibold tracking-wider uppercase", eyebrowColor]}>
        {eyebrow}
      </p>
    )
  }
  <h2 class:list={["mt-3 text-3xl font-semibold tracking-tight sm:text-4xl", titleColor]}>
    {title}
  </h2>
  {
    description && (
      <p class:list={["mt-4 text-base leading-7 sm:text-lg", descColor]}>{description}</p>
    )
  }
</div>
