---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  links: readonly NavLink[];
  currentHref: string;
  label?: string;
}

const { links, currentHref, label = "Section navigation" } = Astro.props;
---

<nav aria-label={label} class="border-b border-slate-200 bg-white">
  <div class="mx-auto w-full max-w-[1440px] px-6 sm:px-8 lg:px-12 xl:px-16">
    <ul class="flex flex-wrap items-center gap-x-6 gap-y-3 py-4 text-sm font-medium">
      {
        links.map((link) => {
          const isActive = link.href === currentHref;
          return (
            <li>
              <a
                href={link.href}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "inline-flex items-center rounded-full px-3 py-1.5 transition",
                  isActive
                    ? "bg-slate-900 text-white"
                    : "text-slate-600 hover:bg-slate-100 hover:text-slate-900",
                ]}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>
