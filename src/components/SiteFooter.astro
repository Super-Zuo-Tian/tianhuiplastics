      { label: "Awards & Recognitions", href: "/about/awards-recognitions/" },
      { label: "Our History", href: "/about/our-history/" },
      { label: "TIANHUI Values", href: "/about/tianhui-values/" },
    ],
  },
  {
    title: "Products",
    links: [
      { label: "Products & Services", href: "/products/" },
      { label: "Polystyrene (PS)", href: "/products/polystyrene/" },
      { label: "HDPE", href: "/products/hdpe/" },
      { label: "LLDPE", href: "/products/lldpe/" },
      { label: "LDPE", href: "/products/ldpe/" },
      { label: "Polypropylene (PP)", href: "/products/polypropylene/" },
      { label: "ABS Resin", href: "/products/abs/" },
