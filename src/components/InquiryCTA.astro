---
import Container from "./Container.astro";

interface Props {
  title?: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  lang?: "en" | "zh";
}

const pathname = Astro.url.pathname;
const isZh = (Astro.props.lang ?? (pathname === "/zh" || pathname.startsWith("/zh/") ? "zh" : "en")) === "zh";

const defaults = isZh
  ? {
      title: "需要天晖为您供应树脂原料？",
      description:
        "请告知所需牌号、起订量与目的港口，我们的团队将在一个工作日内回复。",
      primaryLabel: "提交询价",
      primaryHref: "/zh/contact/",
      secondaryLabel: "浏览产品",
      secondaryHref: "/zh/products/",
    }
  : {
      title: "Ready to source resins from TIANHUI?",
      description:
        "Tell us your grade, MOQ and destination port. Our export team will respond within one business day.",
      primaryLabel: "Send an inquiry",
      primaryHref: "/contact/",
      secondaryLabel: "Explore products",
      secondaryHref: "/products/",
    };

const {
  title = defaults.title,
  description = defaults.description,
  primaryLabel = defaults.primaryLabel,
  primaryHref = defaults.primaryHref,
  secondaryLabel = defaults.secondaryLabel,
  secondaryHref = defaults.secondaryHref,
} = Astro.props;
---

<section class="bg-brand-50 py-16 sm:py-20">
  <div class="mx-auto flex max-w-4xl flex-col items-center px-6 text-center sm:px-8">
    <h2 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
      {title}
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-base text-slate-600 sm:text-lg">
      {description}
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-4">
      <a
        href={primaryHref}
        class="inline-flex items-center justify-center rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-500"
      >
        {primaryLabel}
      </a>
      <a
        href={secondaryHref}
        class="inline-flex items-center gap-1 text-sm font-semibold text-slate-900 transition hover:text-brand-700"
      >
        {secondaryLabel}
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>
